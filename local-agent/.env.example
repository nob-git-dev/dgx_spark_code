# LLM
OLLAMA_MODEL=gpt-oss-120b-128k
EMBEDDING_MODEL=nemotron-3-nano

# Server
AGENT_PORT=8090
LOG_LEVEL=INFO

# Sandbox (absolute host path for workspace volume sharing)
# Set this to the absolute path of the data/workspace directory on your host
WORKSPACE_HOST_PATH=/path/to/local-agent/data/workspace
