# ==========================================
# Nemotron-9B-v2-Japanese NVFP4 on vLLM
# DGX Spark (GB10 Grace Blackwell / ARM64)
# ==========================================

VLLM_IMAGE_TAG=26.01-py3

# HuggingFace トークン（量子化時にモデルダウンロードで必要）
# HF_TOKEN=hf_xxxxxxxxxxxx

HF_CACHE_VOLUME=vllm_hf_cache
MAX_MODEL_LEN=32768

CHAT_PORT=8001
# NVFP4 量子化済み（6.3GB）のため 0.20 で十分
GPU_MEMORY_UTIL_CHAT=0.20
