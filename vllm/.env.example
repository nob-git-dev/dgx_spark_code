# ==========================================
# vLLM マルチモデル設定
# ==========================================

# vLLM コンテナバージョン（ARM64 + Blackwell 対応済み）
VLLM_IMAGE_TAG=26.01-py3

# HuggingFace トークン（プライベートモデルを使う場合のみ設定）
# HF_TOKEN=hf_xxxxxxxxxxxx

# HuggingFace キャッシュ（モデルの保存先ボリューム名、両サービスで共有）
HF_CACHE_VOLUME=vllm_hf_cache

# 最大コンテキスト長（共通）
MAX_MODEL_LEN=32768

# ------------------------------------------
# OCR・画像認識用 VLM（ポート 8000）
# ------------------------------------------
OCR_MODEL=Qwen/Qwen3-VL-8B-Instruct
OCR_PORT=8000
# 2サービス同時起動のため 0.28 に設定（約36GB確保）
GPU_MEMORY_UTIL_OCR=0.28

# ------------------------------------------
# 日本語チャット・エージェント用 LLM（ポート 8001）
# ------------------------------------------
CHAT_MODEL=nvidia/NVIDIA-Nemotron-Nano-9B-v2-Japanese
CHAT_PORT=8001
# 2サービス同時起動のため 0.28 に設定（約36GB確保）
GPU_MEMORY_UTIL_CHAT=0.28

# ==========================================
# メモリ割り当ての目安（128GB 統合メモリ）
# ==========================================
# vllm-ocr:  128GB × 0.28 = 36GB（モデル~16GB + KVキャッシュ~20GB）
# vllm-chat: 128GB × 0.28 = 36GB（モデル~18GB + KVキャッシュ~18GB）
# 合計:      約72GB使用 / 56GB 空き
# ==========================================
